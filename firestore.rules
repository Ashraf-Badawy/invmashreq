rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - id: string (required)
    //   - username: string (required)
    //   - password: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: admin, user, observer)
    //   - name: string (required)
    //
    // Collection: items
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - quantity: number (required)
    //   - unit: string (required)
    //   - lowThreshold: number (optional)
    //   - criticalThreshold: number (optional)
    //
    // Collection: transactions
    // Fields:
    //   - id: string (required)
    //   - itemId: string (required)
    //   - itemName: string (required)
    //   - quantity: number (required)
    //   - user: string (required)
    //   - date: string (required)
    //   - type: string (required, enum: withdraw, receive)
    //
    // Collection: orders
    // Fields:
    //   - id: string (required)
    //   - item: string (required)
    //   - quantity: number (required)
    //   - order_date: string (required)
    //   - delivery_date: string (optional)
    //   - status: string (required, enum: pending, delivered, cancelled)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "AshrafBadawy33@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 &&
             data.role in ['admin', 'user', 'observer'];
    }

    function isValidItem(data) {
      return data.name is string && data.name.size() > 0 &&
             data.quantity is number &&
             data.unit is string;
    }

    function isValidTransaction(data) {
      return data.itemId is string &&
             data.itemName is string &&
             data.quantity is number &&
             data.user is string &&
             data.type in ['withdraw', 'receive'];
    }

    function isValidOrder(data) {
      return data.item is string &&
             data.quantity is number &&
             data.status in ['pending', 'delivered', 'cancelled'];
    }

    // Test connection
    match /test/connection {
      allow read, write: if true;
    }

    // User profiles and private data
    match /users/{userId} {
      allow read, write: if true;

      // Nested collections for isolation
      match /items/{itemId} {
        allow read, write: if true;
      }

      match /transactions/{transactionId} {
        allow read, write: if true;
      }

      match /orders/{orderId} {
        allow read, write: if true;
      }
    }
  }
}
